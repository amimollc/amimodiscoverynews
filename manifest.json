{
  "name": "Amimo Discovery",
  "short_name": "Amimo News",
  "description": "Discovering and browsing local and worldwide news.",
  "start_url": "/amimodiscoverynews/",
  "scope": "/amimodiscoverynews/",
  "display": "standalone",
  "display_override": ["window-controls-overlay", "tabbed", "fullscreen"],
  "orientation": "any",
  "theme_color": "#0659ef",
  "background_color": "#ffffff",
  "lang": "en",
  "dir": "auto",
  "categories": ["news", "magazines", "sports", "weather"],
  "icons": [
    { "src": "/amimodiscoverynews/icons/icon-72x72.png", "sizes": "72x72", "type": "image/png", "purpose": "any" },
    { "src": "/amimodiscoverynews/icons/icon-96x96.png", "sizes": "96x96", "type": "image/png", "purpose": "any" },
    { "src": "/amimodiscoverynews/icons/icon-128x128.png", "sizes": "128x128", "type": "image/png", "purpose": "any" },
    { "src": "/amimodiscoverynews/icons/icon-144x144.png", "sizes": "144x144", "type": "image/png", "purpose": "any" },
    { "src": "/amimodiscoverynews/icons/icon-152x152.png", "sizes": "152x152", "type": "image/png", "purpose": "any" },
    { "src": "/amimodiscoverynews/icons/icon-192x192.png", "sizes": "192x192", "type": "image/png", "purpose": "any" },
    { "src": "/amimodiscoverynews/icons/icon-256x256.png", "sizes": "256x256", "type": "image/png", "purpose": "any" },
    { "src": "/amimodiscoverynews/icons/icon-384x384.png", "sizes": "384x384", "type": "image/png", "purpose": "any" },
    { "src": "/amimodiscoverynews/icons/icon-512x512.png", "sizes": "512x512", "type": "image/png", "purpose": "any" },
    { "src": "/amimodiscoverynews/icons/icon-maskable.png", "sizes": "512x512", "type": "image/png", "purpose": "maskable" }
  ],
  "screenshots": [
    {
      "src": "/amimodiscoverynews/screenshots/screenshot-wide.png",
      "sizes": "1280x720",
      "type": "image/png",
      "form_factor": "wide",
      "label": "Homepage on desktop"
    },
    {
      "src": "/amimodiscoverynews/screenshots/screenshot-narrow.png",
      "sizes": "720x1280",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Mobile article view"
    }
  ],
  "shortcuts": [
    {
      "name": "Top News",
      "short_name": "Top",
      "description": "Latest headlines",
      "url": "/amimodiscoverynews/top",
      "icons": [{ "src": "/amimodiscoverynews/icons/icon-96x96.png", "sizes": "96x96", "type": "image/png" }]
    },
    {
      "name": "Saved Articles",
      "short_name": "Saved",
      "description": "Your reading list",
      "url": "/amimodiscoverynews/saved",
      "icons": [{ "src": "/amimodiscoverynews/icons/icon-96x96.png", "sizes": "96x96", "type": "image/png" }]
    }
  ],
  "share_target": {
    "action": "/amimodiscoverynews/share",
    "method": "GET",
    "params": { "title": "title", "text": "text", "url": "url" }
  },
  "tab_strip": { "home_tab": "auto" }
    }

{
  "name": "Amimo Discovery",
  "short_name": "Amimo News",
  "description": "Discovering and browsing local and worldwide news.",
  "start_url": "/amimodiscoverynews/",
  "scope": "/amimodiscoverynews/",
  "display": "standalone",
  "display_override": ["window-controls-overlay", "tabbed"],
  "background_color": "#ffffff",
  "theme_color": "#0659ef",
  "orientation": "any",
  "lang": "en",
  "categories": ["news", "magazines", "sports", "weather"],
  "icons": [
    { "src": "/amimodiscoverynews/favicon.png", "sizes": "192x192", "type": "image/png", "purpose": "any" },
    { "src": "/amimodiscoverynews/favicon.png", "sizes": "512x512", "type": "image/png", "purpose": "any" },
    { "src": "/amimodiscoverynews/favicon.png", "sizes": "512x512", "type": "image/png", "purpose": "maskable" }
  ],
  "screenshots": [
    { 
      "src": "/amimodiscoverynews/screenshot-wide.png", 
      "sizes": "1280x720", 
      "type": "image/png", 
      "form_factor": "wide", 
      "label": "Home Page" 
    },
    { 
      "src": "/amimodiscoverynews/screenshot-narrow.png", 
      "sizes": "720x1280", 
      "type": "image/png", 
      "form_factor": "narrow", 
      "label": "Mobile View" 
    }
  ],
  "shortcuts": [
    { 
      "name": "Top News", 
      "short_name": "Top", 
      "description": "View the latest headlines", 
      "url": "/amimodiscoverynews/top", 
      "icons": [{ "src": "/amimodiscoverynews/favicon.png", "sizes": "96x96", "type": "image/png" }] 
    },
    { 
      "name": "Saved Articles", 
      "short_name": "Saved", 
      "description": "Your reading list", 
      "url": "/amimodiscoverynews/saved", 
      "icons": [{ "src": "/amimodiscoverynews/favicon.png", "sizes": "96x96", "type": "image/png" }] 
    }
  ],
  "tab_strip": { "home_tab": "auto" },
  "edge_side_panel": { "preferred_width": 400 },
  "share_target": {
    "action": "/amimodiscoverynews/share",
    "method": "GET",
    "params": { "title": "title", "text": "text", "url": "url" }
  }
    }
